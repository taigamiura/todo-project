{
  "name": "todo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "generate:api-types": "npm run generate:api-types:bff && npm run generate:api-types:user-service && npm run generate:api-types:todo-service",
    "generate:api-types:bff": "openapi-typescript ../openapi/bff.yaml -o ./src/lib/api/generated/bff.ts",
    "generate:api-types:user-service": "openapi-typescript ../openapi/user-service.yaml -o ./src/lib/api/generated/user-service.ts",
    "generate:api-types:todo-service": "openapi-typescript ../openapi/todo-service.yaml -o ./src/lib/api/generated/todo-service.ts",
    "lint": "eslint",
    "test": "vitest run --coverage",
    "test:all": "npm test && npm run test:api:mock",
    "test:api:mock": "./scripts/run-api-contract-tests.sh",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@vercel/otel": "^1.13.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "prom-client": "^15.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}